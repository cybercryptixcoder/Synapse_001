{
  "name": "code_prediction",
  "description": "Assistant asks for prediction, waits, then shows outputs in terminal.",
  "events": [
    {"type": "speech", "role": "assistant", "text": "Predict the output if start index is 1."},
    {"type": "speech", "role": "user", "text": "It will return the same array."},
    {"type": "tool_call", "name": "emit_canvas_patches", "arguments": {"patches": [
      {"op": "add", "component": {"kind": "outputTerminal", "id": "output-terminal-1", "entries": []}},
      {"op": "update", "id": "output-terminal-1", "path": "/entries/0", "value": {"kind": "stdout", "text": "[1,2,3]"}},
      {"op": "update", "id": "output-terminal-1", "path": "/entries/1", "value": {"kind": "stdout", "text": "[1,3,2]"}}
    ]}},
    {"type": "speech", "role": "assistant", "text": "The off-by-one shifts the merge; see output-terminal-1."}
  ]
}
