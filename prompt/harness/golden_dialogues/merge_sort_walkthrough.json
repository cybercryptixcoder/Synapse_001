{
  "name": "merge_sort_walkthrough",
  "description": "Assistant introduces merge sort, builds steps, streams code without reading it.",
  "events": [
    {"type": "speech", "role": "user", "text": "Explain merge sort."},
    {"type": "speech", "role": "assistant", "text": "Merge sort splits the array..."},
    {"type": "tool_call", "name": "emit_canvas_patches", "arguments": {"patches": [{"op": "add", "component": {"kind": "stepList", "id": "merge-steps", "steps": [{"id": "step-1", "text": "Split the array"}]}}]}},
    {"type": "speech", "role": "assistant", "text": "Then we merge sorted halves..."},
    {"type": "tool_call", "name": "emit_canvas_patches", "arguments": {"patches": [{"op": "update", "id": "merge-steps", "path": "/steps/1", "value": {"id": "step-2", "text": "Merge halves"}}]}},
    {"type": "speech", "role": "assistant", "text": "Here is the code."},
    {"type": "tool_call", "name": "emit_canvas_patches", "arguments": {"patches": [{"op": "add", "component": {"kind": "codeViewer", "id": "merge-code", "language": "javascript", "code": "function mergeSort(arr){...}"}}]}}
  ]
}
